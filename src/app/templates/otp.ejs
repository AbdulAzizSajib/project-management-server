<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your OTP - Bariyan</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background-color: #f4f6f9;
      color: #333;
    }
    .wrapper {
      max-width: 600px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    .header {
      background: linear-gradient(135deg, #1a6b3c, #25a05a);
      padding: 36px 40px;
      text-align: center;
    }
    .header .brand {
      font-size: 30px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: 1px;
    }
    .header .tagline {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.8);
      margin-top: 6px;
      letter-spacing: 0.4px;
    }
    .body {
      padding: 40px 40px 32px;
    }
    .greeting {
      font-size: 20px;
      font-weight: 600;
      color: #1a1a1a;
      margin-bottom: 12px;
    }
    .message {
      font-size: 15px;
      color: #555;
      line-height: 1.7;
      margin-bottom: 32px;
    }
    .otp-box {
      background: #f0faf4;
      border: 1.5px dashed #25a05a;
      border-radius: 10px;
      padding: 28px 20px;
      text-align: center;
      margin-bottom: 32px;
    }
    .otp-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #888;
      margin-bottom: 10px;
    }
    .otp-code {
      font-size: 42px;
      font-weight: 800;
      letter-spacing: 10px;
      color: #1a6b3c;
    }
    .otp-expiry {
      font-size: 13px;
      color: #e05a2b;
      margin-top: 10px;
      font-weight: 500;
    }
    .notice {
      font-size: 13px;
      color: #999;
      background: #fafafa;
      border-left: 3px solid #ddd;
      padding: 12px 16px;
      border-radius: 4px;
      line-height: 1.6;
      margin-bottom: 24px;
    }
    .footer {
      background: #f9f9f9;
      border-top: 1px solid #eee;
      padding: 24px 40px;
      text-align: center;
    }
    .footer p {
      font-size: 12px;
      color: #aaa;
      line-height: 1.8;
    }
    .footer a {
      color: #25a05a;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="brand">Bariyan</div>
      <div class="tagline">Property Management for Bangladeshi Landlords, Real Estate Firms and Housing Societies</div>
    </div>

    <div class="body">
      <p class="greeting">Hello, <%= name %></p>
      <p class="message">
        We received a request to verify your identity. Use the one-time password below to proceed.
        Do not share this code with anyone.
      </p>

      <div class="otp-box">
        <div class="otp-label">Your One-Time Password</div>
        <div class="otp-code"><%= otp %></div>
        <div class="otp-expiry">Expires in 5 minutes</div>
      </div>

      <div class="notice">
        If you did not request this OTP, please ignore this email or contact our support team immediately.
        Your account security is our priority.
      </div>
    </div>

    <div class="footer">
      <p>
        &copy; <%= new Date().getFullYear() %> Bariyan &mdash; All rights reserved.<br />
        This is an automated message. Please do not reply to this email.<br />
        <a href="#">Support</a> &nbsp;&middot;&nbsp; <a href="#">Privacy Policy</a>
      </p>
    </div>
  </div>
</body>
</html>
