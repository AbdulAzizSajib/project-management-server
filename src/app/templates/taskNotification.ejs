<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= heading %></title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        background: #f3f5f7;
        color: #20262d;
      }
      .container {
        max-width: 640px;
        margin: 24px auto;
        background: #ffffff;
        border: 1px solid #e7ecf1;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(20, 32, 50, 0.08);
      }
      .header {
        background: linear-gradient(135deg, #0f766e, #0e9f6e);
        color: #ffffff;
        padding: 28px 32px;
      }
      .header.overdue {
        background: linear-gradient(135deg, #b91c1c, #ef4444);
      }
      .header h1 {
        margin: 0;
        font-size: 22px;
        line-height: 1.3;
      }
      .content {
        padding: 28px 32px;
        line-height: 1.7;
        font-size: 15px;
      }
      .meta {
        margin: 18px 0;
        padding: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
      }
      .button-wrap {
        margin: 26px 0;
        text-align: center;
      }
      .button {
        display: inline-block;
        background: #0f766e;
        color: #ffffff !important;
        text-decoration: none;
        padding: 12px 22px;
        border-radius: 8px;
        font-weight: 600;
      }
      .footer {
        border-top: 1px solid #edf2f7;
        padding: 16px 32px;
        font-size: 12px;
        color: #718096;
        background: #fafcfe;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header <%= isOverdue ? 'overdue' : '' %>">
        <h1><%= heading %></h1>
      </div>

      <div class="content">
        <p>Hello <strong><%= recipientName %></strong>,</p>
        <p><%= message %></p>

        <div class="meta">
          <div>Task: <strong><%= taskTitle %></strong></div>
          <div>Project: <strong><%= projectName %></strong></div>
          <% if (dueDate) { %>
          <div>Due: <strong><%= new Date(dueDate).toUTCString() %></strong></div>
          <% } %>
        </div>

        <% if (taskUrl) { %>
        <div class="button-wrap">
          <a class="button" href="<%= taskUrl %>">Open task</a>
        </div>
        <% } %>
      </div>

      <div class="footer">
        This is an automated email from your project management workspace.
      </div>
    </div>
  </body>
</html>
