{
	"info": {
		"_postman_id": "b3e9a2c1-4f7d-4a2e-9c1b-8f2a6d5e7c10",
		"name": "Project Management API",
		"description": "Auth endpoints for the Project Management backend (Express + better-auth + Prisma/MySQL).\n\nBase URL variable: `{{baseUrl}}` (default http://localhost:5000).\n\nMost cookies (accessToken, refreshToken, better-auth.session_token) are set httpOnly by the server and stored automatically in Postman's cookie jar per domain, so protected requests just work after login. The `accessToken`/`refreshToken` are also captured into collection variables where returned in the body.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 201', () => pm.response.to.have.status(201));",
									"const json = pm.response.json();",
									"if (json?.data?.user?.email) {",
									"    pm.collectionVariables.set('userEmail', json.data.user.email);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"123456\",\n    \"contactNumber\": \"01700000000\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Register a new user. Email must be verified via OTP before tokens are issued."
					}
				},
				{
					"name": "Verify Email (OTP)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{userEmail}}\",\n    \"otp\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/verify-email",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "verify-email"]
						},
						"description": "Verify email with the 4-digit OTP sent on registration. Returns access + refresh tokens."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"john@example.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Login with email OR phone number (`identifier`) and password. Sets httpOnly cookies and returns tokens."
					}
				},
				{
					"name": "Get Me",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "me"]
						},
						"description": "Get the currently authenticated user's profile. Requires the accessToken + session cookies set by login."
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/refresh-token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "refresh-token"]
						},
						"description": "Issue new access/refresh tokens using the refreshToken + session cookies."
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"123456\",\n    \"newPassword\": \"1234567\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "change-password"]
						},
						"description": "Change the password for the logged-in user. Requires auth cookies."
					}
				},
				{
					"name": "Resend Verification OTP",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/resend-verification-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "resend-verification-otp"]
						},
						"description": "Resend the email-verification OTP."
					}
				},
				{
					"name": "Resend Password Reset OTP",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/resend-password-reset-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "resend-password-reset-otp"]
						},
						"description": "Resend the password-reset OTP (email must already be verified)."
					}
				},
				{
					"name": "Forget Password",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/forget-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "forget-password"]
						},
						"description": "Send a password-reset OTP to the user's email."
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"otp\": \"1234\",\n    \"newPassword\": \"newpass123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/reset-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "reset-password"]
						},
						"description": "Reset the password using the OTP from forget-password."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "logout"]
						},
						"description": "Log out the current user and clear auth cookies."
					}
				},
				{
					"name": "Google Login (browser)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login/google?redirect=/dashboard",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login", "google"],
							"query": [
								{ "key": "redirect", "value": "/dashboard" }
							]
						},
						"description": "Starts the Google OAuth flow. Open this in a browser (redirect-based) — not testable purely in Postman."
					}
				}
			],
			"description": "Authentication & account endpoints."
		},
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/",
					"host": ["{{baseUrl}}"],
					"path": [""]
				},
				"description": "Basic API health check."
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "userEmail", "value": "" }
	]
}
